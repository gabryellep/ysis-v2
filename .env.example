# Ysis V2 backend environment example. Do not put real secrets in this file.

ENVIRONMENT=development

# Backend-only Supabase configuration.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-project-anon-key

# Service role must stay only in server environments and must never be exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Guest and temporary session metadata only; relato/audio are not persisted by default.
GUEST_SESSION_TTL_MINUTES=120

# Frontend may point to this backend URL. It is not a secret.
NEXT_PUBLIC_YSIS_API_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Default safe local setup: no external AI call.
AI_PROVIDER=mock
AI_MODEL=gpt-5.5

TRANSCRIPTION_PROVIDER=mock
TRANSCRIPTION_MODEL=gpt-4o-transcribe
TRANSCRIPTION_MAX_UPLOAD_MB=12
OPENAI_API_KEY=

# Profile 1 - production / sensitive relatos, backend-only OpenAI.
# AI_PROVIDER=openai
# AI_MODEL=gpt-5.5
# TRANSCRIPTION_PROVIDER=openai
# TRANSCRIPTION_MODEL=gpt-4o-transcribe
# OPENAI_API_KEY=replace-with-backend-only-key

# Profile 2 - cheaper OpenAI development.
# AI_PROVIDER=openai
# AI_MODEL=gpt-4.1-mini
# TRANSCRIPTION_PROVIDER=openai
# TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# OPENAI_API_KEY=replace-with-backend-only-key

# Profile 3 - free/local development without OpenAI credits.
# AI_PROVIDER=local
# LOCAL_LLM_URL=http://127.0.0.1:11434
# LOCAL_LLM_MODEL=llama3.1:8b
# TRANSCRIPTION_PROVIDER=local
# LOCAL_TRANSCRIPTION_MODEL=base
#
# If Ollama/faster-whisper are unavailable, the backend falls back to mock safely.
